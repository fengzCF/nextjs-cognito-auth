# AWS Cognito Configuration
# Copy this file to .env.local and fill in your values

# Your AWS Cognito User Pool ID (e.g., us-east-1_xxxxxxxxx)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=

# Your AWS Cognito App Client ID (e.g., 1234567890abcdefghijklmnop)
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# Your AWS region where Cognito is hosted (e.g., us-east-1)
NEXT_PUBLIC_COGNITO_REGION=

# Optional: Domain for OAuth (if using hosted UI)
# NEXT_PUBLIC_COGNITO_DOMAIN=

# Optional: OAuth redirect sign-in URL
# NEXT_PUBLIC_OAUTH_REDIRECT_SIGN_IN=http://localhost:3000/

# Optional: OAuth redirect sign-out URL
# NEXT_PUBLIC_OAUTH_REDIRECT_SIGN_OUT=http://localhost:3000/
